NODE_ENV=development
PORT=3000

# Used by docker-compose to provision the Postgres container
POSTGRES_USER=peopleflow
POSTGRES_PASSWORD=peopleflow
POSTGRES_DB=peopleflow
POSTGRES_PORT=5432

# Used by Prisma + the app when running locally (outside docker-compose),
# e.g. `npm run dev` against a Postgres started via `docker-compose up postgres`.
# Inside docker-compose, the app container gets its own DATABASE_URL
# (pointed at the "postgres" service name) set directly in docker-compose.yml.
DATABASE_URL=postgresql://peopleflow:peopleflow@localhost:5432/peopleflow?schema=public
